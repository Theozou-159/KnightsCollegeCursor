dgn1.cur
dgn2.ani
dgn2.cur

[TheoScheme]
HKCU,"Control Panel\Cursors\Schemes","Theo Cursor Image2",0x00000000,"%10%\Cursors\TheoCursorImage2\pointer.ani,%10%\Cursors\TheoCursorImage2\help.ani,%10%\Cursors\TheoCursorImage2\work.ani,%10%\Cursors\TheoCursorImage2\busy.ani,%10%\Cursors\TheoCursorImage2\cross.ani,%10%\Cursors\TheoCursorImage2\text.ani,%10%\Cursors\TheoCursorImage2\pointer.cur,%10%\Cursors\TheoCursorImage2\unavailable.ani,%10%\Cursors\TheoCursorImage2\vert.ani,%10%\Cursors\TheoCursorImage2\horz.ani,%10%\Cursors\TheoCursorImage2\dgn1.ani,%10%\Cursors\TheoCursorImage2\dgn2.ani,%10%\Cursors\TheoCursorImage2\move.ani,%10%\Cursors\TheoCursorImage2\pointer.cur,%10%\Cursors\TheoCursorImage2\link.ani"
HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\Runonce\Setup\","",,"rundll32.exe shell32.dll,Control_RunDLL main.cpl,,1"

