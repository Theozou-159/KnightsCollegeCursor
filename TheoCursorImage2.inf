[Version]
Signature="$CHICAGO$"

[DefaultInstall]
CopyFiles=TheoCursors
AddReg=TheoScheme

[DestinationDirs]
TheoCursors=10,"Cursors\TheoCursorImage2"

[TheoCursors]
