[Version]
Signature="$CHICAGO$"

[DefaultInstall]
CopyFiles=DiderichCursors
AddReg=DiderichScheme

[DestinationDirs]
DiderichCursors=10,"Cursors\DiderichCursor"

[DiderichCursors]
pointer.ani
pointer.cur
help.ani
help.cur
work.ani
work.cur
busy.ani
busy.cur
text.ani
text.cur
link.ani
link.cur
unavailable.ani
unavailable.cur
move.ani
move.cur
cross.ani
cross.cur
vert.ani
vert.cur
horz.ani
horz.cur
dgn1.ani
dgn1.cur
dgn2.ani
dgn2.cur

[DiderichScheme]
HKCU,"Control Panel\Cursors\Schemes","Diderich Cursor",0x00000000,"%10%\Cursors\DiderichCursor\pointer.ani,%10%\Cursors\DiderichCursor\help.ani,%10%\Cursors\DiderichCursor\work.ani,%10%\Cursors\DiderichCursor\busy.ani,%10%\Cursors\DiderichCursor\cross.ani,%10%\Cursors\DiderichCursor\text.ani,%10%\Cursors\DiderichCursor\pointer.cur,%10%\Cursors\DiderichCursor\unavailable.ani,%10%\Cursors\DiderichCursor\vert.ani,%10%\Cursors\DiderichCursor\horz.ani,%10%\Cursors\DiderichCursor\dgn1.ani,%10%\Cursors\DiderichCursor\dgn2.ani,%10%\Cursors\DiderichCursor\move.ani,%10%\Cursors\DiderichCursor\pointer.cur,%10%\Cursors\DiderichCursor\link.ani"
HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\Runonce\Setup\","",,"rundll32.exe shell32.dll,Control_RunDLL main.cpl,,1"

[SourceDisksNames]
1="Diderich Cursor","",1

[SourceDisksFiles]
